# HoldCrew Casting — environment (copy to .env; .env is gitignored)

# HTTP port (reels is :4000; casting uses :4100)
CASTING_PORT=4100

# Subdomain base — <company>.casting.holdcrew.com
CASTING_BASE_DOMAIN=casting.holdcrew.com
# Local/dev fallback tenant when there's no subdomain (localhost/IP)
CASTING_DEFAULT_TENANT=upshot

# Per-tenant builder password lives in the DB (tenants.password). This is only a
# one-time seed for the dev tenant, mirroring reels' REELS_PASSWORD seed.
CASTING_PASSWORD=

# ── Wasabi (S3-compatible) ────────────────────────────────────────────────
# Dedicated casting bucket. Reuses the existing upshot-reels-app SUB-USER key
# (a casting-bucket policy is attached to it). Root key stays offline.
WASABI_ENDPOINT=https://s3.wasabisys.com
WASABI_REGION=us-east-1
WASABI_CASTING_BUCKET=holdcrew-casting
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
SIGNED_URL_TTL=7200
